#version 450

layout(local_size_x = 128, local_size_y = 1, local_size_z = 1) in;

#include "sparse_common.inc"

void main() {
    uint idx = gl_GlobalInvocationID.x;
    if (idx >= p.n) return;
    uint block = idx / SCAN_BLOCK_SIZE;
    int offset = block == 0u ? 0 : i2[block - 1u];
    i1[idx] = i0[idx] + offset;
}
