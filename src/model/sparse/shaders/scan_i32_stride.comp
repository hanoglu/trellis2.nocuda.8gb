#version 450

layout(local_size_x = 128, local_size_y = 1, local_size_z = 1) in;

#include "sparse_common.inc"

void main() {
    uint idx = gl_GlobalInvocationID.x;
    if (idx >= p.n) return;
    uint stride = p.flags;
    int value = i0[idx];
    if (idx >= stride) {
        value += i0[idx - stride];
    }
    i1[idx] = value;
}
